# Proje başlangıcı: Yasaklı alan ihlali tespiti

import cv2
import numpy as np
import sqlite3
from datetime import datetime
from ultralytics import YOLO
from shapely.geometry import Point, Polygon

# --- 1. VERİTABANI KURULUMU ---
def init_db():
    conn = sqlite3.connect("ihlal_kayitlari.db")
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS ihlaller (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nesne_id INTEGER,
            baslangic_zamani TEXT,
            bitis_zamani TEXT,
            sure_saniye REAL
        )
    """)
    conn.commit()
    conn.close()

def ihlal_kaydet(nesne_id, baslangic, bitis, sure):
    conn = sqlite3.connect("ihlal_kayitlari.db")
    cursor = conn.cursor()
    cursor.execute("""
        INSERT INTO ihlaller (nesne_id, baslangic_zamani, bitis_zamani, sure_saniye)
        VALUES (?, ?, ?, ?)
    """, (nesne_id, baslangic.strftime("%Y-%m-%d %H:%M:%S"), bitis.strftime("%Y-%m-%d %H:%M:%S"), round(sure, 2)))
    conn.commit()
    conn.close()
    print(f"📌 [KAYIT BİLGİSİ] ID: {nesne_id} | Süre: {round(sure, 2)} sn (YOLO Pose)")

init_db()

# --- 2. POSE MODELİ ---
model = YOLO("yolov8n-pose.pt")  # Pose tahmini yapan model

video_yolu = r"Placeholder.mp4"
cap = cv2.VideoCapture(video_yolu)

# Yasaklı Alan Poligonu
RED_ZONE_PTS = np.array([[100, 100], [100, 2500], [3000, 2500], [3000, 100]], np.int32)
red_polygon = Polygon(RED_ZONE_PTS)

aktif_ihlaller = {}

# --- PENCERE BOYUTUNU EKRANA SIĞDIRMA AYARI ---
# Orijinal boyutları al
orig_w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
orig_h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

# Ekrana sığacak maksimum boyut sınırları
MAX_W, MAX_H = 1024, 720

# En/Boy oranını bozmadan ölçek faktörünü bul
scale = min(MAX_W / orig_w, MAX_H / orig_h)
